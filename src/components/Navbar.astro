---
import type { SiteConfig } from "../types/config";
import { withBase } from "../utils/base-path";
import { matchPath } from "../utils/match-path";
import GithubIcon from "./GithubIcon.astro";
import SearchModal from "./SearchModal.astro";

type Props = {
	config: SiteConfig;
	currentPath: string;
};

const { config, currentPath } = Astro.props;
---

<header class="sticky top-0 z-50 h-16 border-b border-white/10 bg-black/80 backdrop-blur-md">
	<div class="max-w-7xl h-full mx-auto px-6 md:px-8 flex items-center justify-between">
		<div class="flex items-center gap-2">
			{config.parentSite && (
				<>
					<a
						href={config.parentSite.href}
						class="flex items-center gap-1.5 text-white/50 hover:text-white/80 transition-colors"
					>
						{config.parentSite.logoSrc ? (
							<img src={config.parentSite.logoSrc} alt={config.parentSite.label} class="h-5" />
						) : (
							<span class="text-sm font-medium">{config.parentSite.label}</span>
						)}
					</a>
					<span class="text-white/20 text-sm select-none">/</span>
				</>
			)}
			<a href={withBase("/")} class="flex items-center gap-3 text-white hover:opacity-80 transition-opacity">
				{config.logoSrc ? (
					<img src={withBase(config.logoSrc)} alt={config.logoAlt ?? config.title} class="h-7" />
				) : (
					<span class="text-base font-semibold tracking-tight">{config.title}</span>
				)}
			</a>
		</div>

		<nav class="hidden md:flex items-center gap-6">
			{config.navLinks.map((link) => (
				<a
					href={withBase(link.href)}
					class:list={[
						"text-sm font-medium transition-colors duration-150",
						matchPath(currentPath, link.href)
							? "text-white"
							: "text-white/60 hover:text-white/90",
					]}
				>
					{link.label}
				</a>
			))}
			<button
				id="search-trigger"
				type="button"
				class="flex items-center gap-2 rounded-lg border border-white/10 bg-white/[0.03] hover:bg-white/[0.06] px-3 py-1.5 text-white/50 hover:text-white/70 transition-colors cursor-pointer"
			>
				<svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5">
					<circle cx="11" cy="11" r="7" />
					<line x1="16.5" y1="16.5" x2="21" y2="21" />
				</svg>
				<span class="text-xs">Search</span>
				<kbd class="ml-2 rounded border border-white/10 bg-white/[0.04] px-1.5 py-0.5 text-[10px] font-mono text-white/40">
					<span class="text-[10px]">&#8984;</span>K
				</kbd>
			</button>
			<a
				href={config.githubUrl}
				target="_blank"
				rel="noopener noreferrer"
				class="text-white/50 hover:text-white/80 transition-colors duration-150"
			>
				<GithubIcon class="w-5" />
			</a>
		</nav>

		<div class="flex items-center gap-3 md:hidden">
			<button
				id="search-trigger-mobile"
				type="button"
				class="text-white/60 hover:text-white transition-colors cursor-pointer"
				aria-label="Search"
			>
				<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5">
					<circle cx="11" cy="11" r="7" />
					<line x1="16.5" y1="16.5" x2="21" y2="21" />
				</svg>
			</button>
			<button
				id="mobile-nav-toggle"
				type="button"
				class="text-white/70 hover:text-white transition-colors cursor-pointer"
				aria-label="Toggle menu"
			>
				<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 6h16M4 12h16M4 18h16" />
				</svg>
			</button>
		</div>
	</div>
</header>

<div id="mobile-nav-overlay" class="fixed inset-0 z-40 bg-black/60 backdrop-blur-sm hidden md:hidden"></div>

<nav
	id="mobile-nav-menu"
	class="fixed top-0 right-0 z-50 h-dvh w-72 bg-black border-l border-white/10 transform translate-x-full transition-transform duration-200 ease-out md:hidden overflow-y-auto"
>
	<div class="flex items-center justify-between px-6 py-5 border-b border-white/10">
		<div class="flex items-center gap-2">
			{config.parentSite && (
				<>
					<a
						href={config.parentSite.href}
						class="text-white/50 hover:text-white/80 transition-colors"
					>
						{config.parentSite.logoSrc ? (
							<img src={config.parentSite.logoSrc} alt={config.parentSite.label} class="h-4" />
						) : (
							<span class="text-sm font-medium">{config.parentSite.label}</span>
						)}
					</a>
					<span class="text-white/20 text-xs select-none">/</span>
				</>
			)}
			<span class="text-sm font-semibold text-white">{config.title}</span>
		</div>
		<button
			id="mobile-nav-close"
			type="button"
			class="text-white/70 hover:text-white transition-colors cursor-pointer"
			aria-label="Close menu"
		>
			<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
				<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M6 18L18 6M6 6l12 12" />
			</svg>
		</button>
	</div>

	<div class="px-6 py-4 flex flex-col gap-3 border-b border-white/10">
		{config.navLinks.map((link) => (
			<a
				href={withBase(link.href)}
				class:list={[
					"text-sm font-medium transition-colors",
					matchPath(currentPath, link.href)
						? "text-white"
						: "text-white/60 hover:text-white/90",
				]}
			>
				{link.label}
			</a>
		))}
	</div>

	{config.sidebarSections.length > 0 && (
		<div class="px-6 py-4">
			{config.sidebarSections.map((section) => (
				<div class="mb-5">
					<div class="text-xs font-semibold uppercase tracking-widest text-white/40 mb-2">
						{section.title}
					</div>
					<div class="flex flex-col">
						{section.links.map((link) => (
							<a
								href={withBase(link.href)}
								class:list={[
									"block py-1.5 pl-3 text-sm border-l-2 transition-colors",
									matchPath(currentPath, link.href)
										? "border-accent text-white font-medium"
										: "border-transparent text-white/60 hover:text-white/90 hover:border-white/20",
								]}
							>
								{link.label}
							</a>
						))}
					</div>
				</div>
			))}
		</div>
	)}

	<div class="px-6 py-4 border-t border-white/10 mt-auto flex gap-4">
		<a
			href={config.socialLinks.github}
			target="_blank"
			rel="noopener noreferrer"
			class="text-white/40 hover:text-white/70 transition-colors"
		>
			<GithubIcon class="w-5" />
		</a>
	</div>
</nav>

<SearchModal />

<script>
	function initMobileNav() {
		const toggle = document.getElementById("mobile-nav-toggle");
		const close = document.getElementById("mobile-nav-close");
		const overlay = document.getElementById("mobile-nav-overlay");
		const menu = document.getElementById("mobile-nav-menu");

		function open() {
			overlay?.classList.remove("hidden");
			menu?.classList.remove("translate-x-full");
			document.body.style.overflow = "hidden";
		}

		function shut() {
			overlay?.classList.add("hidden");
			menu?.classList.add("translate-x-full");
			document.body.style.overflow = "";
		}

		toggle?.addEventListener("click", open);
		close?.addEventListener("click", shut);
		overlay?.addEventListener("click", shut);
	}

	initMobileNav();
	document.addEventListener("astro:after-swap", initMobileNav);
</script>
