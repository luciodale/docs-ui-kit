---
type FeatureColor = "accent" | "blue" | "green" | "purple" | "yellow" | "cyan";

type FeatureItem = {
	highlight: string;
	description?: string;
	color?: FeatureColor;
};

type Props = {
	features: FeatureItem[];
	color?: FeatureColor;
};

const { features, color = "accent" } = Astro.props;

const colorMap: Record<FeatureColor, { text: string }> = {
	accent: { text: "text-accent" },
	blue: { text: "text-blue-400" },
	green: { text: "text-green-400" },
	purple: { text: "text-purple-400" },
	yellow: { text: "text-yellow-400" },
	cyan: { text: "text-cyan-400" },
};
---

<ul class="flex flex-col gap-3 list-none m-0 p-0">
	{features.map((feature) => {
		const c = colorMap[feature.color ?? color];
		return (
			<li class="flex items-start gap-3">
				<span class="text-base leading-relaxed">
					<span class:list={["font-semibold", c.text]}>{feature.highlight}</span>
					{feature.description && (
						<span class="text-white/70">{" "}&mdash; {feature.description}</span>
					)}
				</span>
			</li>
		);
	})}
</ul>
