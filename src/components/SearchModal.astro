---
// Search dialog. Uses Pagefind (loaded dynamically from /_pagefind/).
// The consumer must run `npx pagefind --site <dist>` after building.
// Trigger buttons live in Navbar.astro; this component renders only the dialog.
---
<dialog id="search-dialog">
	<div class="search-dialog-panel">
		<div class="search-dialog-header">
			<svg class="search-dialog-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5">
				<circle cx="11" cy="11" r="7" />
				<line x1="16.5" y1="16.5" x2="21" y2="21" />
			</svg>
			<input
				id="search-input"
				type="text"
				placeholder="Search documentation..."
				autocomplete="off"
				class="search-dialog-input"
			/>
			<kbd class="search-dialog-kbd">esc</kbd>
		</div>
		<div id="search-results" class="search-dialog-results">
			<p class="search-dialog-placeholder">Type to search...</p>
		</div>
	</div>
</dialog>

<style>
	#search-dialog {
		position: fixed;
		inset: 0;
		z-index: 100;
		margin: 0;
		padding: 0;
		height: 100dvh;
		width: 100dvw;
		max-height: 100dvh;
		max-width: 100dvw;
		background: transparent;
		border: none;
		display: none;
	}

	#search-dialog[open] {
		display: flex;
		align-items: flex-start;
		justify-content: center;
		padding-top: 12vh;
	}

	#search-dialog::backdrop {
		background: rgb(0 0 0 / 0.6);
		backdrop-filter: blur(8px);
	}

	.search-dialog-panel {
		width: 100%;
		max-width: min(36rem, 100dvw - 2rem);
		border-radius: 0.75rem;
		border: 1px solid rgb(255 255 255 / 0.1);
		background: #0a0a0a;
		box-shadow: 0 25px 50px -12px rgb(0 0 0 / 0.25);
		overflow: hidden;
	}

	.search-dialog-header {
		display: flex;
		align-items: center;
		gap: 0.75rem;
		padding: 0.75rem 1rem;
		border-bottom: 1px solid rgb(255 255 255 / 0.06);
	}

	.search-dialog-icon {
		width: 0.875rem;
		height: 0.875rem;
		color: rgb(255 255 255 / 0.4);
		flex-shrink: 0;
	}

	.search-dialog-input {
		flex: 1;
		background: transparent;
		font-size: 0.875rem;
		color: white;
		outline: none;
	}

	.search-dialog-input::placeholder {
		color: rgb(255 255 255 / 0.4);
	}

	.search-dialog-kbd {
		border-radius: 0.25rem;
		border: 1px solid rgb(255 255 255 / 0.1);
		background: rgb(255 255 255 / 0.04);
		padding: 0.125rem 0.375rem;
		font-size: 10px;
		font-family: ui-monospace, monospace;
		color: rgb(255 255 255 / 0.4);
	}

	.search-dialog-results {
		max-height: 50vh;
		overflow-y: auto;
		padding: 0.5rem;
	}

	.search-dialog-placeholder {
		padding: 1.5rem 0.75rem;
		text-align: center;
		font-size: 0.875rem;
		color: rgb(255 255 255 / 0.4);
	}

	#search-results :global(mark) {
		background: transparent;
		color: var(--color-accent);
		font-weight: 600;
	}
</style>

<script>
	type PagefindSubResult = {
		title: string;
		url: string;
		excerpt: string;
	};

	type PagefindResult = {
		url: string;
		excerpt: string;
		meta?: { title?: string };
		sub_results?: PagefindSubResult[];
	};

	type PagefindAPI = {
		init: () => Promise<void>;
		search: (query: string) => Promise<{ results: Array<{ data: () => Promise<PagefindResult> }> }>;
	};

	let pagefind: PagefindAPI | null = null;

	async function loadPagefind(): Promise<PagefindAPI | null> {
		if (pagefind) return pagefind;
		try {
			const base = import.meta.env.BASE_URL.replace(/\/$/, "");
			const path = `${base}/_pagefind/pagefind.js`;
			pagefind = await import(/* @vite-ignore */ path) as PagefindAPI;
			await pagefind.init();
			return pagefind;
		} catch {
			return null;
		}
	}

	type FlatResult = { title: string; section?: string; url: string; excerpt: string };

	function flattenResults(items: PagefindResult[]): FlatResult[] {
		const flat: FlatResult[] = [];
		for (const item of items) {
			const pageTitle = item.meta?.title ?? item.url;
			if (item.sub_results && item.sub_results.length > 0) {
				for (const sub of item.sub_results) {
					flat.push({
						title: sub.title || pageTitle,
						section: sub.title && sub.title !== pageTitle ? pageTitle : undefined,
						url: sub.url,
						excerpt: sub.excerpt,
					});
				}
			} else {
				flat.push({ title: pageTitle, url: item.url, excerpt: item.excerpt });
			}
		}
		return flat.slice(0, 10);
	}

	function ensureAbsolute(url: string): string {
		return url.startsWith("/") ? url : `/${url}`;
	}

	function renderResults(items: PagefindResult[], query: string) {
		const container = document.getElementById("search-results");
		if (!container) return;

		const placeholderStyle = "padding: 1.5rem 0.75rem; text-align: center; font-size: 0.875rem; color: rgb(255 255 255 / 0.4);";

		if (!query.trim()) {
			container.innerHTML = `<p style="${placeholderStyle}">Type to search...</p>`;
			return;
		}

		const flat = flattenResults(items);

		if (flat.length === 0) {
			container.innerHTML = `<p style="${placeholderStyle}">No results for &ldquo;${query.replace(/</g, "&lt;")}&rdquo;</p>`;
			return;
		}

		container.innerHTML = flat
			.map(
				(r) => `
			<a href="${ensureAbsolute(r.url)}" style="display: block; border-radius: 0.5rem; padding: 0.625rem 0.75rem; transition: background-color 150ms; text-decoration: none;" onmouseenter="this.style.background='rgb(255 255 255 / 0.04)'" onmouseleave="this.style.background='transparent'" data-search-result>
				<div style="display: flex; align-items: baseline; gap: 0.5rem; margin-bottom: 0.125rem;">
					<span style="font-size: 0.875rem; font-weight: 500; color: rgb(255 255 255 / 0.8);">${r.title}</span>
					${r.section ? `<span style="font-size: 11px; color: rgb(255 255 255 / 0.35);">${r.section}</span>` : ""}
				</div>
				<div style="font-size: 0.75rem; color: rgb(255 255 255 / 0.5); line-height: 1.625; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">${r.excerpt}</div>
			</a>`,
			)
			.join("");
	}

	let debounceTimer: ReturnType<typeof setTimeout>;

	async function handleSearch(query: string) {
		const pf = await loadPagefind();
		if (!pf) {
			const container = document.getElementById("search-results");
			if (container) {
				container.innerHTML = '<p style="padding: 1.5rem 0.75rem; text-align: center; font-size: 0.875rem; color: rgb(255 255 255 / 0.4);">Search not available. Run <code style="font-family: ui-monospace, monospace; color: rgb(255 255 255 / 0.6);">npx pagefind</code> after building.</p>';
			}
			return;
		}

		if (!query.trim()) {
			renderResults([], query);
			return;
		}

		const { results } = await pf.search(query);
		const items = await Promise.all(results.slice(0, 6).map((r) => r.data()));
		renderResults(items, query);
	}

	function initSearch() {
		const triggers = [
			document.getElementById("search-trigger"),
			document.getElementById("search-trigger-mobile"),
		];
		const dialog = document.getElementById("search-dialog") as HTMLDialogElement | null;
		const input = document.getElementById("search-input") as HTMLInputElement | null;

		function openSearch() {
			dialog?.showModal();
			input?.focus();
		}

		for (const trigger of triggers) {
			trigger?.addEventListener("click", openSearch);
		}

		dialog?.addEventListener("click", (e) => {
			if (e.target === dialog) dialog.close();
		});

		input?.addEventListener("input", () => {
			clearTimeout(debounceTimer);
			debounceTimer = setTimeout(() => handleSearch(input.value), 150);
		});

		document.getElementById("search-results")?.addEventListener("click", (e) => {
			const link = (e.target as HTMLElement).closest("[data-search-result]");
			if (link) dialog?.close();
		});

		document.addEventListener("keydown", (e) => {
			if ((e.metaKey || e.ctrlKey) && e.key === "k") {
				e.preventDefault();
				if (dialog?.open) {
					dialog.close();
				} else {
					openSearch();
				}
			}
		});
	}

	initSearch();
	document.addEventListener("astro:after-swap", initSearch);
</script>
