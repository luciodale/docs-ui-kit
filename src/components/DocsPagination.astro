---
import type { SidebarSection } from "../types/config";
import { withBase } from "../utils/base-path";
import { matchPath } from "../utils/match-path";

type Props = {
	sections: Array<SidebarSection>;
	currentPath: string;
};

const { sections, currentPath } = Astro.props;

type FlatLink = { href: string; label: string; sectionTitle: string };

const flat: Array<FlatLink> = sections.flatMap((section) =>
	section.links.map((link) => ({
		href: link.href,
		label: link.label,
		sectionTitle: section.title,
	})),
);

const currentIndex = flat.findIndex((link) => matchPath(currentPath, link.href));
const prev = currentIndex > 0 ? flat[currentIndex - 1] : undefined;
const next =
	currentIndex >= 0 && currentIndex < flat.length - 1
		? flat[currentIndex + 1]
		: undefined;

const hasAny = prev !== undefined || next !== undefined;
---

{hasAny && (
	<nav
		aria-label="Docs pagination"
		class="mt-16 pt-8 border-t border-white/10 grid grid-cols-1 sm:grid-cols-2 gap-4"
	>
		{prev ? (
			<a
				href={withBase(prev.href)}
				class="group flex flex-col gap-1 rounded-lg border border-white/10 bg-white/[0.02] hover:bg-white/[0.05] hover:border-white/20 px-5 py-4 transition-colors sm:col-start-1"
				rel="prev"
			>
				<span class="flex items-center gap-1.5 text-xs font-medium text-white/45 uppercase tracking-wider">
					<svg
						class="w-3 h-3"
						fill="none"
						stroke="currentColor"
						viewBox="0 0 24 24"
						stroke-width="2"
						stroke-linecap="round"
						stroke-linejoin="round"
					>
						<path d="M15 19l-7-7 7-7" />
					</svg>
					Previous
				</span>
				<span class="text-sm font-medium text-white group-hover:text-accent transition-colors">
					{prev.label}
				</span>
				<span class="text-xs text-white/40">{prev.sectionTitle}</span>
			</a>
		) : (
			<div class="hidden sm:block" />
		)}

		{next ? (
			<a
				href={withBase(next.href)}
				class="group flex flex-col gap-1 rounded-lg border border-white/10 bg-white/[0.02] hover:bg-white/[0.05] hover:border-white/20 px-5 py-4 transition-colors text-right sm:col-start-2"
				rel="next"
			>
				<span class="flex items-center justify-end gap-1.5 text-xs font-medium text-white/45 uppercase tracking-wider">
					Next
					<svg
						class="w-3 h-3"
						fill="none"
						stroke="currentColor"
						viewBox="0 0 24 24"
						stroke-width="2"
						stroke-linecap="round"
						stroke-linejoin="round"
					>
						<path d="M9 5l7 7-7 7" />
					</svg>
				</span>
				<span class="text-sm font-medium text-white group-hover:text-accent transition-colors">
					{next.label}
				</span>
				<span class="text-xs text-white/40">{next.sectionTitle}</span>
			</a>
		) : (
			<div class="hidden sm:block" />
		)}
	</nav>
)}
