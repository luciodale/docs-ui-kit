---
type Props = {
	color?: "accent" | "blue" | "green" | "purple" | "yellow" | "cyan" | "default";
};

const { color = "default" } = Astro.props;

const colorMap = {
	default: "text-white/80",
	accent: "text-accent",
	blue: "text-blue-400",
	green: "text-green-400",
	purple: "text-purple-400",
	yellow: "text-yellow-400",
	cyan: "text-cyan-400",
} as const;
---

<code class:list={["font-mono text-sm rounded border border-white/20 px-1 py-0.5", colorMap[color]]}><slot /></code>
